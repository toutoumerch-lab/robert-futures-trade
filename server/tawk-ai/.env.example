# ─────────────────────────────────────────────────────────────
# Tawk.to AI Bot — Environment Variables
# Copy this file to .env and fill in your real values
# ─────────────────────────────────────────────────────────────

# Port for this webhook service (keep separate from your main server)
PORT=3500

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-key-here...
# GPT model to use (gpt-4o is cheapest + fastest, gpt-4-turbo for best quality)
OPENAI_MODEL=gpt-4o
# Max tokens for each reply (keep low to control costs)
OPENAI_MAX_TOKENS=400

# ── Tawk.to REST API ──────────────────────────────────────────
# From tawk.to → Admin → Account → API Access
TAWK_API_KEY=your-tawk-api-key
# Your tawk.to Property ID (from the widget embed script)
TAWK_PROPERTY_ID=69e90a163de6551c3e783256
# Widget/Inbox ID (the second part of your widget script path)
TAWK_INBOX_ID=1jmr4uq9u

# ── Webhook Security ──────────────────────────────────────────
# Secret token to verify webhook requests are genuine (set in tawk.to dashboard → Webhooks → Secret)
WEBHOOK_SECRET=your-webhook-secret

# ── Conversation Memory ────────────────────────────────────────
# How many messages per visitor to remember (higher = better context, more OpenAI tokens)
MEMORY_SIZE=10
# Minutes before a conversation is cleared from memory
MEMORY_TTL_MINUTES=60

# ── System Prompt ─────────────────────────────────────────────
# Customise who the AI is and how it behaves
SYSTEM_PROMPT=You are a helpful and professional support agent for Robert Trades Futures — a premium futures trading education platform. You help users with course questions, account issues, prop firm guidance, and trading concepts. Be concise, friendly, and accurate. If you cannot resolve an issue, tell the user a human agent will follow up shortly.
