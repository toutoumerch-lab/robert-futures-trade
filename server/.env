PORT=5000
DB_USER=postgres
DB_PASSWORD=admin
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roberts_trades_db
JWT_SECRET=supersecretjwtkey_for_dev_only

# ── Tawk.to AI Bot ─────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# GPT model — gpt-4o (cheap+fast) or gpt-4-turbo (best quality)
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=400

# Get from: tawk.to → Profile → API Access → Generate Token
TAWK_API_KEY=your-tawk-api-key-here

# Webhook signature secret — set this same string in tawk.to dashboard
TAWK_WEBHOOK_SECRET=your-webhook-secret-here

# Conversation memory — messages per visitor, TTL in minutes
MEMORY_SIZE=10
MEMORY_TTL_MINUTES=60

# AI personality — edit this freely
TAWK_SYSTEM_PROMPT=You are a helpful and professional support agent for Robert Trades Futures — a premium futures trading education platform. Help users with course questions, account issues, prop firm guidance, and trading concepts. Be concise and friendly. If you cannot resolve an issue, say a human agent will follow up shortly.

